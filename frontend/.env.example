# Backend API URL (Vercel deployed backend)
VITE_API_BASE_URL=http://localhost:8000

# WebSocket URL (auto-derived if not set)
VITE_WS_URL=ws://localhost:8000/live-stream

# Set to "true" to enable mock UI data when WebSocket is unavailable
# This is REQUIRED on Vercel since serverless doesn't support persistent WebSocket
VITE_ALLOW_MOCK_UI=false
