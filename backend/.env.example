APP_NAME="Agentic AI Fraud Detection"
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=agentic_fraud_detection

ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=
BLOCKCHAIN_NETWORK=ethereum
BLOCKCHAIN_CHAIN_ID=1
STREAM_POLL_SECONDS=4
USE_MOCK_STREAM=false
ALLOW_MOCK_FALLBACK=false

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

ENABLE_HF_MODELS=false
HF_FRAUD_MODEL=uyen1109/eth-fraud-gnn-uyenuyen-v3
HF_SCAM_MODEL=Digvijay05/SCAMBERT
